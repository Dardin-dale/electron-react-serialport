{
    "name": "electron-react-serialport",
    "version": "1.0.0",
    "description": "Electron + React boilerplate wiring node-serialport-tutorial's DeviceManager into a desktop app",
    "author": "Logan Crecraft",
    "license": "MIT",
    "type": "module",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "start": "electron-vite preview",
        "dist": "electron-vite build && electron-builder",
        "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "postinstall": "electron-builder install-app-deps"
    },
    "keywords": [
        "electron",
        "react",
        "vite",
        "serialport"
    ],
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@emotion/react": "^11.13.0",
        "@emotion/styled": "^11.13.0",
        "@mui/icons-material": "^6.1.0",
        "@mui/material": "^6.1.0",
        "p-queue": "^8.0.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "serialport": "^13.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.2",
        "electron": "^38.0.0",
        "electron-builder": "^26.0.0",
        "electron-vite": "^5.0.0",
        "typescript": "^6.0.0",
        "vite": "^7.0.0",
        "vitest": "^4.0.0"
    },
    "build": {
        "appId": "com.logancrecraft.electron-react-serialport",
        "productName": "Electron Serialport Boilerplate",
        "directories": {
            "output": "release-builds"
        },
        "files": [
            "out/**/*",
            "package.json"
        ],
        "extraResources": [
            "icon.png"
        ],
        "win": {
            "target": "nsis",
            "icon": "icon.png"
        },
        "linux": {
            "target": "AppImage",
            "icon": "icon.png",
            "category": "Utility"
        },
        "mac": {
            "target": "dmg",
            "icon": "icon.png"
        },
        "nsis": {
            "createDesktopShortcut": "always"
        }
    }
}

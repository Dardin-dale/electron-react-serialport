{
  "name": "electron-serialport-react",
  "version": "1.0.0",
  "description": "A boilerplate for Electron for serialport use",
  "private": true,
  "main": "app/main.js",
  "scripts": {
    "start": "gulp",
    "compile": "gulp build",
    "rebuild": "./node_modules/.bin/electron-rebuild",
    "release": "gulp release",
    "dist": "build"
  },
  "repository": "https://github.com/electron/electron-quick-start",
  "build": {
    "appId": "electron-react-serialport",
    "files": [
      "app/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": null
  },
  "keywords": [
    "Electron",
    "quick",
    "start",
    "tutorial",
    "demo",
    "serial",
    "serialport"
  ],
  "author": "Logan Crecraft",
  "license": "CC0-1.0",
  "devDependencies": {
    "@babel/core": "^7.7.4",
    "@babel/preset-env": "^7.10.3",
    "@babel/preset-react": "^7.7.4",
    "electron": "^7.1.2",
    "electron-builder": "^22.7.0",
    "electron-rebuild": "^1.11.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1"
  },
  "dependencies": {
    "@babel/plugin-proposal-class-properties": "^7.10.1",
    "@babel/polyfill": "^7.10.1",
    "electron-is-dev": "^1.2.0",
    "electron-react-devtools": "^0.5.3",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-livereload": "^4.0.2",
    "npm": "^6.14.5",
    "react-hot-loader": "^4.12.21",
    "react-test-renderer": "^16.13.1",
    "serialport": "^9.0.0"
  }
}
